services:

  # ─── BASE DE DATOS ───────────────────────────────
  postgres:
    build:
      context: ./backend/src/db
      dockerfile: Dockerfile
    container_name: levelup_db
    restart: unless-stopped
    environment:
      POSTGRES_USER:     ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB:       ${DB_NAME}
    ports:
      - "5433:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./backend/src/db/init:/docker-entrypoint-initdb.d
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
      interval: 10s
      timeout:  5s
      retries:  5

  # ─── BACKEND ─────────────────────────────────────
  api:
    build: ./backend/
    container_name: levelup_api
    restart: unless-stopped
    ports:
      - "3001:3000"
    env_file:
      - .env
    environment:
      DB_HOST: postgres
      DATABASE_URL: ""
      NODE_ENV: development
    depends_on:
      postgres:
        condition: service_healthy
    volumes:
      - ./logs:/app/logs

  # ─── FRONTEND ────────────────────────────────────
  frontend:
    build:
      context: ./frontend/
      args:
        VITE_API_URL: ${VITE_API_URL}
    container_name: levelup_frontend
    restart: unless-stopped
    ports:
      - "8080:80"
    depends_on:
      - api

volumes:
  postgres_data: