services:

  # ─── BASE DE DATOS ───────────────────────────────
  postgres:
    image: postgres:16-alpine
    container_name: levelup_db
    restart: unless-stopped
    environment:
      POSTGRES_USER:     ${DB_USER}
      POSTGRES_PASSWORD: ${DB_PASSWORD}
      POSTGRES_DB:       ${DB_NAME}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data  # persiste los datos
      - ./db/init:/docker-entrypoint-initdb.d   # ejecuta scripts al iniciar
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
      interval: 10s
      timeout:  5s
      retries:  5

  # ─── BACKEND ─────────────────────────────────────
  api:
    build: .
    container_name: levelup_api
    restart: unless-stopped
    ports:
      - "${PORT}:${PORT}"
    env_file:
      - .env
    environment:
      DB_HOST: postgres   # ← nombre del servicio, no localhost
    depends_on:
      postgres:
        condition: service_healthy  # espera a que la DB esté lista
    volumes:
      - ./logs:/app/logs  # persiste los logs

volumes:
  postgres_data: